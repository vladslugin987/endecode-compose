{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "endecode-tauri",
  "version": "0.2.0",
  "identifier": "com.sluginv.endecode-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "endecode-tauri",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNDlFRDk3QjU4QTNBNDcKUldSSE9vcTFsKzFKMnFCWHFXb3FJSkJBaG5YN0NsajcxVDlXTDR4Rk5xMzlzNUZhSklIQ3M3VXMK",
      "endpoints": [
        "https://github.com/vladslugin987/endecode-compose/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
